# =============================================================================
# NEXUS HELPDESK AGENT — copy this file to .env and fill in your values
# =============================================================================

# --- CHOOSE ONE AUTH METHOD ---

# Option A: Gemini API Key (simpler — get a free key at https://aistudio.google.com/apikey)
# Available June 22 — use this placeholder until then
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE
GOOGLE_GENAI_USE_VERTEXAI=False

# Option B: Vertex AI (requires Google Cloud project + billing enabled)
# Comment out the two lines above and uncomment these:
# GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID_HERE
# GOOGLE_CLOUD_LOCATION=us-central1

# =============================================================================
# FILLED IN AFTER DEPLOYMENT (leave blank until you deploy to Google Cloud)
# =============================================================================

# The Agent Runtime ID returned by: agents-cli deploy
AGENT_RUNTIME_ID=

# Optional: GCS bucket for telemetry logs (e.g. my-project-logs)
LOGS_BUCKET_NAME=

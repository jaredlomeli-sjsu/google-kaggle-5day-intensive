# =============================================================================
# NEXUS HELPDESK SYSTEM — Master Credentials Template
# Copy relevant sections into each sub-project's .env file
# =============================================================================

# Your Google Cloud Project ID (only needed for Vertex AI / cloud deployment)
GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID_HERE

# Google Cloud region
GOOGLE_CLOUD_LOCATION=us-central1

# --- CHOOSE ONE AUTH METHOD (copy into helpdesk-agent/.env) ---

# Option A: Gemini API Key — get a free key at https://aistudio.google.com/apikey
# Available June 22 — use this placeholder until then
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE
GOOGLE_GENAI_USE_VERTEXAI=False

# Option B: Vertex AI (requires Google Cloud project + billing)
# GOOGLE_GENAI_USE_VERTEXAI=True

# =============================================================================
# FILLED IN AFTER DEPLOYMENT (leave blank until you deploy)
# =============================================================================

AGENT_RUNTIME_ID=
DASHBOARD_URL=
LOGS_BUCKET_NAME=

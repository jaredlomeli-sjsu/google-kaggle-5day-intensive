        "role": "user",
        "parts": [{"text": "Client dinner at Michelin restaurant - $380.00, 4 attendees, business development meeting"}]
      },
      "expected_route": "human_review",
      "expected_keywords": ["HUMAN REVIEW REQUIRED", "380.00"]
    },
    {
      "eval_case_id": "pii_ssn_blocked",

# Manager Dashboard — copy to .env and fill in your values

# Your Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID_HERE

# Region where Agent Runtime is deployed
GOOGLE_CLOUD_LOCATION=us-central1

# The Agent Runtime ID from: agents-cli deploy (fill in after deployment)
AGENT_RUNTIME_ID=

# The public URL of this dashboard after Cloud Run deployment (fill in after deployment)
DASHBOARD_URL=

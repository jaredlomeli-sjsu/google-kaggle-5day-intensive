# =============================================================================
# GOOGLE CLOUD CREDENTIALS — copy this file to .env and fill in your values
# =============================================================================

# Your Google Cloud Project ID (found in the Google Cloud Console dashboard)
GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID_HERE

# Your Google Cloud region (recommended: us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# --- CHOOSE ONE AUTH METHOD ---
# Option A: Gemini API Key (simpler, get it at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE
GOOGLE_GENAI_USE_VERTEXAI=False

# Option B: Vertex AI (requires Google Cloud project + billing enabled)
# Comment out the two lines above and uncomment these:
# GOOGLE_GENAI_USE_VERTEXAI=True
# (run: gcloud auth application-default login  — no key file needed)

# =============================================================================
# FILLED IN AFTER DEPLOYMENT (leave blank until you deploy)
# =============================================================================

# The Agent Runtime ID returned by: agents-cli deploy
AGENT_RUNTIME_ID=

# The Cloud Run URL returned by: gcloud run deploy manager-dashboard
DASHBOARD_URL=

# Optional: GCS bucket for telemetry logs (e.g. gs://my-project-logs)
LOGS_BUCKET_NAME=
